# =============================================================================
# Configuração de Ambiente do OpenClaude
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores:
#   cp .env.example .env
#
# Defina apenas as variáveis para o provedor que você deseja usar.
# Todas as outras seções podem permanecer comentadas.
# =============================================================================

# =============================================================================
# CONFIGURAÇÃO DE TODO O SISTEMA (OPCIONAL)
# =============================================================================
# Em vez de usar um arquivo .env por projeto, você pode definir essas variáveis
# em todo o sistema para que o OpenClaude funcione em qualquer diretório na sua máquina.
#
# PASSO 1: Escolha as variáveis do seu provedor na lista abaixo.
# PASSO 2: Defina-as usando o método para o seu sistema operacional (veja mais abaixo).
#
# ── Variáveis do provedor ───────────────────────────────────────────────
#
#   Opção 1 — Anthropic:
#     ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui
#     ANTHROPIC_MODEL=claude-sonnet-4-5              (opcional)
#     ANTHROPIC_BASE_URL=https://api.anthropic.com   (opcional)
#
#   Opção 2 — OpenAI:
#     CLAUDE_CODE_USE_OPENAI=1
#     OPENAI_API_KEY=sk-sua-chave-aqui
#     OPENAI_MODEL=gpt-4o
#     OPENAI_BASE_URL=https://api.openai.com/v1      (opcional)
#
#   Opção 3 — Google Gemini:
#     CLAUDE_CODE_USE_GEMINI=1
#     GEMINI_API_KEY=sua-chave-gemini-aqui
#     GEMINI_MODEL=gemini-2.0-flash
#     GEMINI_BASE_URL=https://generativelanguage.googleapis.com  (opcional)
#
#   Opção 4 — GitHub Models:
#     CLAUDE_CODE_USE_GITHUB=1
#     GITHUB_TOKEN=ghp_seu-token-aqui
#
#   Opção 5 — Ollama (local):
#     CLAUDE_CODE_USE_OPENAI=1
#     OPENAI_BASE_URL=http://localhost:11434/v1
#     OPENAI_API_KEY=ollama
#     OPENAI_MODEL=llama3.2
#
#   Opção 6 — LM Studio (local):
#     CLAUDE_CODE_USE_OPENAI=1
#     OPENAI_BASE_URL=http://localhost:1234/v1
#     OPENAI_MODEL=seu-id-de-modelo-aqui
#     OPENAI_API_KEY=lmstudio                        (opcional)
#
#   Opção 7 — AWS Bedrock (também pode precisar de: aws configure):
#     CLAUDE_CODE_USE_BEDROCK=1
#     AWS_REGION=us-east-1
#     AWS_DEFAULT_REGION=us-east-1
#     AWS_BEARER_TOKEN_BEDROCK=seu-token-bearer-aqui
#     ANTHROPIC_BEDROCK_BASE_URL=https://bedrock-runtime.us-east-1.amazonaws.com
#
#   Opção 8 — Google Vertex AI:
#     CLAUDE_CODE_USE_VERTEX=1
#     ANTHROPIC_VERTEX_PROJECT_ID=seu-id-de-projeto-gcp
#     CLOUD_ML_REGION=us-east5
#     GOOGLE_CLOUD_PROJECT=seu-id-de-projeto-gcp
#
# ── Como definir variáveis em cada sistema operacional ────────────────
#
# macOS (zsh):
#   1. Abra:  nano ~/.zshrc
#   2. Adicione cada variável como:  export NOME_DA_VARIAVEL=valor
#   3. Salve e recarregue:  source ~/.zshrc
#
# Linux (bash):
#   1. Abra:  nano ~/.bashrc
#   2. Adicione cada variável como:  export NOME_DA_VARIAVEL=valor
#   3. Salve e recarregue:  source ~/.bashrc
#
# Windows (PowerShell):
#   Execute para cada variável:
#     [System.Environment]::SetEnvironmentVariable('NOME_DA_VARIAVEL', 'valor', 'User')
#   Depois reinicie seu terminal.
#
# Windows (Prompt de Comando):
#   Execute para cada variável:
#     setx NOME_DA_VARIAVEL valor
#   Depois reinicie seu terminal.
#
# Windows (GUI):
#   Configurações > Sistema > Sobre > Configurações avançadas do sistema >
#   Variáveis de Ambiente > em "Variáveis de usuário", clique em Novo,
#   depois adicione cada variável.
#
# ── Notas importantes ──────────────────────────────────────────────────
#
# SERVIDORES LOCAIS: Se estiver usando o LM Studio ou Ollama, o servidor DEVE estar
# rodando com um modelo carregado antes de você iniciar o OpenClaude —
# caso contrário, você terá erros de conexão.
#
# MUDANDO DE PROVEDORES: Para mudar temporariamente, remova a definição (unset)
# das variáveis relevantes na sua sessão de terminal atual:
#
#   macOS / Linux:
#     unset NOME_DA_VARIAVEL
#     # ex.: unset CLAUDE_CODE_USE_OPENAI OPENAI_BASE_URL OPENAI_MODEL
#
#   Windows (PowerShell — apenas na sessão atual):
#     Remove-Item Env:NOME_DA_VARIAVEL
#
#   Para remover permanentemente uma variável no Windows:
#     [System.Environment]::SetEnvironmentVariable('NOME_DA_VARIAVEL', $null, 'User')
#
# ORDEM DE CARREGAMENTO:
#   Variáveis de ambiente do shell e do sistema são herdadas pelo processo.
#   Arquivos .env do projeto só são usados se o seu launcher ou shell os carregar
#   antes de iniciar o OpenClaude.
# COMPATIBILIDADE:
#   Variáveis em todo o sistema funcionam independentemente de como você roda o OpenClaude:
#   npx, npm install global, bun run, ou node diretamente. Qualquer processo
#   iniciado a partir do seu terminal herda o ambiente do seu shell.
#
# LEMBRETE: Certifique-se de que o .env está no seu .gitignore para evitar commitar segredos.
# =============================================================================

# =============================================================================
# SELEÇÃO DE PROVEDOR — descomente UM bloco abaixo
# =============================================================================

# -----------------------------------------------------------------------------
# Opção 1: Anthropic (padrão — não é necessária a flag de provedor)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui

# Substituir o modelo padrão (opcional)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Usar um endpoint personalizado compatível com Anthropic (opcional)
# ANTHROPIC_BASE_URL=https://api.anthropic.com


# -----------------------------------------------------------------------------
# Opção 2: OpenAI
# -----------------------------------------------------------------------------
# CLAUDE_CODE_USE_OPENAI=1
# OPENAI_API_KEY=sk-sua-chave-aqui
# OPENAI_MODEL=gpt-4o

# Usar um endpoint personalizado compatível com OpenAI (opcional — por padrão api.openai.com)
# OPENAI_BASE_URL=https://api.openai.com/v1


# -----------------------------------------------------------------------------
# Opção 3: Google Gemini
# -----------------------------------------------------------------------------
# CLAUDE_CODE_USE_GEMINI=1
# GEMINI_API_KEY=sua-chave-gemini-aqui
# GEMINI_MODEL=gemini-2.0-flash

# Usar um endpoint Gemini personalizado (opcional)
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai


# -----------------------------------------------------------------------------
# Opção 4: GitHub Models
# -----------------------------------------------------------------------------
# CLAUDE_CODE_USE_GITHUB=1
# GITHUB_TOKEN=ghp_seu-token-aqui


# -----------------------------------------------------------------------------
# Opção 5: Ollama (modelos locais)
# -----------------------------------------------------------------------------
# CLAUDE_CODE_USE_OPENAI=1
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=llama3.2

# -----------------------------------------------------------------------------
# Opção 6: LM Studio (modelos locais)
# -----------------------------------------------------------------------------
# O LM Studio expõe uma API compatível com OpenAI, então usamos o provedor OpenAI.
# Certifique-se de que o LM Studio esteja rodando com o servidor Developer habilitado
# (Aba Developer > ligue o servidor ON).
#
# Passos:
#   1. Baixe e instale o LM Studio de https://lmstudio.ai
#   2. Busque e baixe um modelo (ex. qualquer modelo instruct ou coding)
#   3. Carregue o modelo e inicie o servidor Developer
#   4. Defina OPENAI_MODEL para o ID do modelo mostrado na aba Developer do LM Studio
#
# A URL padrão do servidor é http://localhost:1234 — altere a porta abaixo
# se você configurou uma diferente no LM Studio.
#
# OPENAI_API_KEY é opcional — O LM Studio roda localmente e a ignora.
# Alguns clientes exigem um valor não vazio; se tiver erros de autenticação,
# defina-o como qualquer valor fictício (ex. "lmstudio").
#
# CLAUDE_CODE_USE_OPENAI=1
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_MODEL=seu-id-de-modelo-aqui


# -----------------------------------------------------------------------------
# Opção 7: AWS Bedrock
# -----------------------------------------------------------------------------

# Você também pode precisar das credenciais do AWS CLI configuradas (rode: aws configure)
# ou ter AWS_ACCESS_KEY_ID e AWS_SECRET_ACCESS_KEY definidos no seu
# ambiente além das variáveis abaixo.
#
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1
# AWS_BEARER_TOKEN_BEDROCK=seu-token-bearer-aqui
# ANTHROPIC_BEDROCK_BASE_URL=https://bedrock-runtime.us-east-1.amazonaws.com


# -----------------------------------------------------------------------------
# Opção 8: Google Vertex AI
# -----------------------------------------------------------------------------
# CLAUDE_CODE_USE_VERTEX=1
# ANTHROPIC_VERTEX_PROJECT_ID=seu-id-de-projeto-gcp
# CLOUD_ML_REGION=us-east5
# GOOGLE_CLOUD_PROJECT=seu-id-de-projeto-gcp


# =============================================================================
# AJUSTES OPCIONAIS
# =============================================================================

# Número máximo de tentativas da API em caso de falha (padrão: 10)
# CLAUDE_CODE_MAX_RETRIES=10

# Habilitar modo de tentativa persistente para sessões não assistidas/CI
# Tenta novamente 429/529 indefinidamente com recuo inteligente (smart backoff)
# CLAUDE_CODE_UNATTENDED_RETRY=1

# Habilitar relatório estendido de teclas (protocolo de teclado Kitty)
# Útil para iTerm2, WezTerm, Ghostty se as teclas modificadoras parecerem estranhas
# OPENCLAUDE_ENABLE_EXTENDED_KEYS=1

# Desabilitar linha "Co-authored-by" nos commits do git feitos pelo OpenClaude
# OPENCLAUDE_DISABLE_CO_AUTHORED_BY=1

# Tempo limite personalizado para solicitações de API em milissegundos (padrão: varia)
# API_TIMEOUT_MS=60000

# Habilitar log de depuração (debug)
# CLAUDE_DEBUG=1
